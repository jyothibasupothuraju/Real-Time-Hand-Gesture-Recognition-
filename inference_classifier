import pickle
import cv2
import mediapipe as mp
import numpy as np

# Load model
model_dict = pickle.load(open('./model.p', 'rb'))
model = model_dict['model']

# Use the correct camera index (try 0 or 1)
cap = cv2.VideoCapture(0)

# Mediapipe setup
mp_hands = mp.solutions.hands
mp_drawing = mp.solutions.drawing_utils
mp_drawing_styles = mp.solutions.drawing_styles

hands = mp_hands.Hands(static_image_mode=True, min_detection_confidence=0.3)

# Label map
labels_dict = {0: 'A', 1: 'B', 2: 'c', 3: 'D', 4: 'E' , 5: 'F' , 6: 'G' , 7: 'H' , 8: 'I' , 9: 'J' , 10: 'K' , 11: 'L', 12: 'M', 13: 'N', 14: 'O', 15: 'P', 16: 'Q', 17: 'R', 18: 'A', 19: 'T', 20: 'U', 21: 'V', 22: 'W', 23: 'X', 24: 'Y', 25: 'Z', 26: 'SPACE', }
while True:
    data_aux = []
    x_ = []
    y_ = []
#Capture Frame from Webcam
    ret, frame = cap.read()
    if not ret:
        print("Failed to capture frame")
        break
# Convert Frame to RGB
    H, W, _ = frame.shape
    frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
#MediaPipe works with RGB, but OpenCV captures in BGR.
#Converts it to the right format.

#Detects hands and returns landmark points if a hand is present.
    results = hands.process(frame_rgb)

    if results.multi_hand_landmarks:
        hand_landmarks = results.multi_hand_landmarks[0]  # Only use first hand

        # Visually draws the hand skeleton on the video frame
        mp_drawing.draw_landmarks(
            frame,
            hand_landmarks,
            mp_hands.HAND_CONNECTIONS,
            mp_drawing_styles.get_default_hand_landmarks_style(),
            mp_drawing_styles.get_default_hand_connections_style()
        )
        #Gets all x and y coordinates of landmarks to calculate bounding box.
        for lm in hand_landmarks.landmark:
            x_.append(lm.x)
            y_.append(lm.y)
        #Normalize Landmark Coordinates
        for lm in hand_landmarks.landmark:
            data_aux.append(lm.x - min(x_))
            data_aux.append(lm.y - min(y_))
        #Converts normalized coordinates into pixel positions.
        x1 = int(min(x_) * W) - 10
        y1 = int(min(y_) * H) - 10
        x2 = int(max(x_) * W) + 10
        y2 = int(max(y_) * H) + 10
       #Feeds the processed landmarks to the trained model.
        prediction = model.predict([np.asarray(data_aux)])
        predicted_character = labels_dict[int(prediction[0])]
        #Display Prediction
        cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 0, 0), 4)
        cv2.putText(frame, predicted_character, (x1, y1 - 10),
                    cv2.FONT_HERSHEY_SIMPLEX, 3.5, (0, 0, 0), 2, cv2.LINE_AA)
    #Displays the current video frame in a window.
    cv2.imshow('frame', frame)
    if cv2.waitKey(1) & 0xFF == 27:  # Press Esc to exit
        break
#Closes the webcam and all OpenCV windows.
cap.release()
cv2.destroyAllWindows()
